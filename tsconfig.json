{
    "extends": "@tsconfig/strictest/tsconfig.json",
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "moduleResolution": "bundler",
        "module": "ESNext",
        "esModuleInterop": true,
        "sourceMap": false,
        "noEmitOnError": true,
        "jsx": "react",
        "types": ["chrome"],
        "lib": ["ESNext", "DOM"],
        "exactOptionalPropertyTypes": false,
        "allowUnreachableCode": true
    },
    "include": ["src", "manifest.config.ts", "vite.config.ts"]
}
